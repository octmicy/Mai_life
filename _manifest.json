                     ],
    "i18n":  {
                 "default_locale":  "zh-CN",
                 "supported_locales":  [
                                           "zh-CN"
                                       ]
             },
    "urls":  {
                 "repository":  "https://github.com/octmicy/Mai_life",
                 "homepage":  "https://github.com/octmicy/Mai_life",
                 "documentation":  "https://docs.mai-mai.org"
             }
}